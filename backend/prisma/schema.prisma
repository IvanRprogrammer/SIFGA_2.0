model roles {
  id_rol      Int        @id @default(autoincrement()) @db.UnsignedTinyInt
  nombre      String     @unique(map: "nombre") @db.VarChar(20)
  descripcion String?    @db.VarChar(100)
  activo      Boolean    @default(true)
  created_at  DateTime?  @default(now()) @db.Timestamp(0)
  usuarios    usuarios[]
}

model tarifas_especiales {
  id_tarifa_especial Int       @id @default(autoincrement()) @db.UnsignedInt
  id_cliente         Int       @unique(map: "id_cliente") @db.UnsignedInt
  tarifa_agua_m3     Decimal?  @db.Decimal(10, 2)
  plazo_pago_dias    Int?      @db.UnsignedSmallInt
  created_at         DateTime? @default(now()) @db.Timestamp(0)
  updated_at         DateTime? @default(now()) @db.Timestamp(0)
  clientes           clientes  @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction, map: "tarifas_especiales_ibfk_1")
}

model tipos_permiso {
  id_tipo_permiso     Int                   @id @default(autoincrement()) @db.UnsignedTinyInt
  nombre              String                @unique(map: "nombre") @db.VarChar(20)
