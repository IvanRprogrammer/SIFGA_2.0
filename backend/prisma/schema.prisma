generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model auditoria {
  id_auditoria BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  id_usuario   Int?      @db.UnsignedInt
  accion       String    @db.VarChar(100)
  modulo       String    @db.VarChar(50)
  detalle      Json?
  ip_address   String?   @db.VarChar(45)
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  usuarios     usuarios? @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "auditoria_ibfk_1")

  @@index([created_at], map: "idx_auditoria_fecha")
  @@index([modulo], map: "idx_auditoria_modulo")
  @@index([id_usuario], map: "idx_auditoria_usuario")
}

model clientes {
  id_cliente          Int                   @id @default(autoincrement()) @db.UnsignedInt
  nombres             String                @db.VarChar(100)
  apellidos           String                @db.VarChar(100)
  cedula              String                @unique(map: "cedula") @db.VarChar(20)
  direccion           String?               @db.VarChar(255)
  telefono            String?               @db.VarChar(20)
  correo              String?               @db.VarChar(150)
  numero_contador     String                @unique(map: "numero_contador") @db.VarChar(50)
  id_municipio        Int?                  @db.UnsignedSmallInt
  id_estrato          Int?                  @db.UnsignedTinyInt
  deuda_actual        Decimal               @default(0.00) @db.Decimal(12, 2)
  estado              clientes_estado       @default(activo)
  fecha_ingreso       DateTime              @db.Date
  created_at          DateTime?             @default(now()) @db.Timestamp(0)
  updated_at          DateTime?             @default(now()) @db.Timestamp(0)
  municipios          municipios?           @relation(fields: [id_municipio], references: [id_municipio], onDelete: NoAction, onUpdate: NoAction, map: "clientes_ibfk_1")
  estratos            estratos?             @relation(fields: [id_estrato], references: [id_estrato], onDelete: NoAction, onUpdate: NoAction, map: "clientes_ibfk_2")
  facturas            facturas[]
  lecturas            lecturas[]
  pagos               pagos[]
  permisos_vendedores permisos_vendedores[]
  tarifas_especiales  tarifas_especiales?

  @@index([id_estrato], map: "id_estrato")
  @@index([id_municipio], map: "id_municipio")
  @@index([cedula], map: "idx_clientes_cedula")
  @@index([numero_contador], map: "idx_clientes_contador")
  @@index([estado], map: "idx_clientes_estado")
}

model configuracion {
  id_config                        Int       @id @default(autoincrement()) @db.UnsignedTinyInt
  tarifa_agua_m3                   Decimal   @default(2800.00) @db.Decimal(10, 2)
  tarifa_alcantarillado_porcentaje Decimal   @default(45.00) @db.Decimal(5, 2)
  tarifa_aseo_porcentaje           Decimal   @default(30.00) @db.Decimal(5, 2)
  plazo_pago_dias                  Int       @default(30) @db.UnsignedSmallInt
  interes_mora_porcentaje          Decimal   @default(2.00) @db.Decimal(5, 2)
  cargo_fijo                       Decimal   @default(5000.00) @db.Decimal(10, 2)
  created_at                       DateTime? @default(now()) @db.Timestamp(0)
  updated_at                       DateTime? @default(now()) @db.Timestamp(0)
}

model consecutivos_factura {
  id_consecutivo Int @id @default(autoincrement()) @db.UnsignedTinyInt
  anio           Int @unique(map: "uq_anio") @db.UnsignedSmallInt
  ultimo_numero  Int @default(0) @db.UnsignedInt
}

model estados_factura {
  id_estado_factura Int        @id @default(autoincrement()) @db.UnsignedTinyInt
  nombre            String     @unique(map: "nombre") @db.VarChar(20)
  facturas          facturas[]
}

model estados_propuesta {
  id_estado_propuesta Int                   @id @default(autoincrement()) @db.UnsignedTinyInt
  nombre              String                @unique(map: "nombre") @db.VarChar(20)
  propuestas_clientes propuestas_clientes[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model estratos {
  id_estrato          Int                   @id @default(autoincrement()) @db.UnsignedTinyInt
  numero              Int                   @unique(map: "numero") @db.UnsignedTinyInt
  nombre              String                @db.VarChar(30)
  porcentaje_subsidio Decimal               @default(0.00) @db.Decimal(5, 2)
  clientes            clientes[]
  propuestas_clientes propuestas_clientes[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model facturas {
  id_factura           Int             @id @default(autoincrement()) @db.UnsignedInt
  codigo_factura       String          @unique(map: "codigo_factura") @db.VarChar(30)
  id_cliente           Int             @db.UnsignedInt
  id_lectura           Int?            @db.UnsignedInt
  periodo              String          @db.VarChar(50)
  fecha_emision        DateTime        @db.Date
  fecha_vencimiento    DateTime        @db.Date
  id_estado            Int             @db.UnsignedTinyInt
  lectura_anterior     Decimal         @db.Decimal(10, 2)
  lectura_actual       Decimal         @db.Decimal(10, 2)
  consumo_m3           Decimal         @db.Decimal(10, 2)
  tarifa_agua          Decimal         @db.Decimal(10, 2)
  valor_agua           Decimal         @db.Decimal(12, 2)
  valor_alcantarillado Decimal         @db.Decimal(12, 2)
  valor_aseo           Decimal         @db.Decimal(12, 2)
  subtotal             Decimal         @db.Decimal(12, 2)
  porcentaje_subsidio  Decimal         @default(0.00) @db.Decimal(5, 2)
  descuento_subsidio   Decimal         @default(0.00) @db.Decimal(12, 2)
  contribucion         Decimal         @default(0.00) @db.Decimal(12, 2)
  cargo_fijo           Decimal         @default(0.00) @db.Decimal(10, 2)
  mora_anterior        Decimal         @default(0.00) @db.Decimal(12, 2)
  total_pagar          Decimal         @db.Decimal(12, 2)
  id_usuario_creacion  Int             @db.UnsignedInt
  created_at           DateTime?       @default(now()) @db.Timestamp(0)
  updated_at           DateTime?       @default(now()) @db.Timestamp(0)
  clientes             clientes        @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction, map: "facturas_ibfk_1")
  lecturas             lecturas?       @relation(fields: [id_lectura], references: [id_lectura], onDelete: NoAction, onUpdate: NoAction, map: "facturas_ibfk_2")
  estados_factura      estados_factura @relation(fields: [id_estado], references: [id_estado_factura], onDelete: NoAction, onUpdate: NoAction, map: "facturas_ibfk_3")
  usuarios             usuarios        @relation(fields: [id_usuario_creacion], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "facturas_ibfk_4")
  pagos                pagos[]

  @@index([id_lectura], map: "id_lectura")
  @@index([id_usuario_creacion], map: "id_usuario_creacion")
  @@index([id_cliente], map: "idx_facturas_cliente")
  @@index([codigo_factura], map: "idx_facturas_codigo")
  @@index([id_estado], map: "idx_facturas_estado")
  @@index([fecha_vencimiento], map: "idx_facturas_fecha_vencimiento")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model lecturas {
  id_lectura       Int        @id @default(autoincrement()) @db.UnsignedInt
  id_cliente       Int        @db.UnsignedInt
  id_usuario       Int        @db.UnsignedInt
  fecha_lectura    DateTime   @db.Date
  lectura_anterior Decimal    @db.Decimal(10, 2)
  lectura_actual   Decimal    @db.Decimal(10, 2)
  consumo_m3       Decimal?   @db.Decimal(10, 2)
  observaciones    String?    @db.Text
  created_at       DateTime?  @default(now()) @db.Timestamp(0)
  facturas         facturas[]
  clientes         clientes   @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction, map: "lecturas_ibfk_1")
  usuarios         usuarios   @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "lecturas_ibfk_2")

  @@index([id_usuario], map: "id_usuario")
  @@index([id_cliente], map: "idx_lecturas_cliente")
  @@index([fecha_lectura], map: "idx_lecturas_fecha")
}

model medios_pago {
  id_medio_pago Int     @id @default(autoincrement()) @db.UnsignedTinyInt
  nombre        String  @unique(map: "nombre") @db.VarChar(50)
  activo        Boolean @default(true)
  pagos         pagos[]
}

model municipios {
  id_municipio        Int                   @id @default(autoincrement()) @db.UnsignedSmallInt
  nombre              String                @db.VarChar(100)
  region              String?               @db.VarChar(100)
  activo              Boolean               @default(true)
  clientes            clientes[]
  propuestas_clientes propuestas_clientes[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model pagos {
  id_pago       Int         @id @default(autoincrement()) @db.UnsignedInt
  id_factura    Int         @db.UnsignedInt
  id_cliente    Int         @db.UnsignedInt
  id_usuario    Int?        @db.UnsignedInt
  id_medio_pago Int         @db.UnsignedTinyInt
  valor         Decimal     @db.Decimal(12, 2)
  referencia    String?     @db.VarChar(100)
  fecha_pago    DateTime    @db.Date
  created_at    DateTime?   @default(now()) @db.Timestamp(0)
  facturas      facturas    @relation(fields: [id_factura], references: [id_factura], onDelete: NoAction, onUpdate: NoAction, map: "pagos_ibfk_1")
  clientes      clientes    @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction, map: "pagos_ibfk_2")
  usuarios      usuarios?   @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "pagos_ibfk_3")
  medios_pago   medios_pago @relation(fields: [id_medio_pago], references: [id_medio_pago], onDelete: NoAction, onUpdate: NoAction, map: "pagos_ibfk_4")

  @@index([id_medio_pago], map: "id_medio_pago")
  @@index([id_usuario], map: "id_usuario")
  @@index([id_cliente], map: "idx_pagos_cliente")
  @@index([id_factura], map: "idx_pagos_factura")
  @@index([fecha_pago], map: "idx_pagos_fecha")
}

model permisos_vendedores {
  id_permiso       Int           @id @default(autoincrement()) @db.UnsignedInt
  id_vendedor      Int           @db.UnsignedInt
  id_cliente       Int           @db.UnsignedInt
  id_tipo_permiso  Int           @db.UnsignedTinyInt
  fecha_expiracion DateTime?     @db.Date
  activo           Boolean       @default(true)
  created_at       DateTime?     @default(now()) @db.Timestamp(0)
  updated_at       DateTime?     @default(now()) @db.Timestamp(0)
  usuarios         usuarios      @relation(fields: [id_vendedor], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "permisos_vendedores_ibfk_1")
  clientes         clientes      @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction, map: "permisos_vendedores_ibfk_2")
  tipos_permiso    tipos_permiso @relation(fields: [id_tipo_permiso], references: [id_tipo_permiso], onDelete: NoAction, onUpdate: NoAction, map: "permisos_vendedores_ibfk_3")

  @@unique([id_vendedor, id_cliente, id_tipo_permiso], map: "uq_vendedor_cliente_tipo")
  @@index([id_cliente], map: "id_cliente")
  @@index([id_tipo_permiso], map: "id_tipo_permiso")
}

